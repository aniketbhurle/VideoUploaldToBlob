{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureStorage": {
    "ConnectionString": "YOUR_STORAGE_ACCOUNT_CONNECTION_STRING",
    "VideoContainerName": "videos"
  },
  "AzureServiceBus": {
    "ConnectionString": "YOUR_SERVICE_BUS_CONNECTION_STRING",
    "VideoUploadedQueueName": "video-uploaded"
  },
  "VideoUpload": {
    "MaxFileSizeMB": 500
  }
}
